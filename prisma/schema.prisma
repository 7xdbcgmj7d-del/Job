generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  name       String
  avatarUrl  String?
  title      String?
  status     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model AuthChallenge {
  id           String    @id
  email        String
  otpDigest    String
  ipAddress    String?
  attemptCount Int       @default(0)
  expiresAt    DateTime
  consumedAt   DateTime?
  createdAt    DateTime  @default(now())

  @@index([email, createdAt])
  @@index([ipAddress, createdAt])
}

